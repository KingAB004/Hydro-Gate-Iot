rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Announcements - All users can read, only authenticated can write
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Notifications - Only authenticated users
    match /notifications/{notificationId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Notification errors - Only system can write
    match /notification_errors/{errorId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // User data
    match /users/{userId} {
      // Temporary for simulation/admin dashboard without enforced login session.
      allow read, write: if true;
    }
    
    // Water level data (for monitoring)
    match /water_levels/{levelId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Flood gate status
    match /flood_gates/{gateId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
