rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Announcements - All users can read, only authenticated can write
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Notifications - Only authenticated users
    match /notifications/{notificationId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Notification errors - Only system can write
    match /notification_errors/{errorId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // User data
    match /users/{userId} {
      allow read, write: if true; // Temporary for simulation
    }

    // Devices (Station monitoring)
    match /devices/{deviceId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Water level data
    match /water_levels/{levelId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Flood gate status
    match /flood_gates/{gateId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Smart alerts
    match /alerts/{alertId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Audit logs (Firestore copy/backup)
    match /audit_logs/{logId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
